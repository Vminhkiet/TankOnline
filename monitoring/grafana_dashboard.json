{
  "title": "Tank Online — System Monitoring",
  "uid": "tank-online-monitor",
  "tags": ["tank-online", "game-server"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Active Matches",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 40 },
              { "color": "red", "value": 60 }
            ]
          },
          "unit": "none"
        }
      },
      "targets": [{ "expr": "tank_active_matches", "legendFormat": "matches" }]
    },
    {
      "id": 2,
      "title": "Tick Avg (µs)",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green",  "value": 0 },
              { "color": "yellow", "value": 5000 },
              { "color": "red",    "value": 12000 }
            ]
          },
          "unit": "µs",
          "max": 16667
        }
      },
      "targets": [{ "expr": "tank_tick_duration_us_avg", "legendFormat": "avg" }]
    },
    {
      "id": 3,
      "title": "Tick P99 (µs)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green",  "value": 0 },
              { "color": "yellow", "value": 8000 },
              { "color": "red",    "value": 14000 }
            ]
          },
          "unit": "µs",
          "max": 16667
        }
      },
      "targets": [{ "expr": "tank_tick_duration_us_p99", "legendFormat": "p99" }]
    },
    {
      "id": 4,
      "title": "Tick Overruns (total)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green",  "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red",    "value": 10 }
            ]
          }
        }
      },
      "targets": [{ "expr": "tank_tick_overruns_total", "legendFormat": "overruns" }]
    },
    {
      "id": 5,
      "title": "Java Services UP/DOWN",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1 }]
          }
        }
      },
      "targets": [{ "expr": "tank_java_service_up", "legendFormat": "{{service}}" }]
    },
    {
      "id": 10,
      "title": "Tick Duration over Time (avg / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 16, "h": 9 },
      "fieldConfig": {
        "defaults": { "unit": "µs", "min": 0 },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Budget 16,667µs" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [6, 3], "fill": "dash" } },
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      },
      "targets": [
        { "expr": "tank_tick_duration_us_avg", "legendFormat": "avg" },
        { "expr": "tank_tick_duration_us_p95", "legendFormat": "p95" },
        { "expr": "tank_tick_duration_us_p99", "legendFormat": "p99" },
        { "expr": "tank_tick_duration_us_max", "legendFormat": "max (spike)" },
        { "expr": "16667",                     "legendFormat": "Budget 16,667µs" }
      ]
    },
    {
      "id": 11,
      "title": "Tick Budget Usage %",
      "type": "gauge",
      "gridPos": { "x": 16, "y": 4, "w": 8, "h": 9 },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100, "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green",  "value": 0 },
              { "color": "yellow", "value": 50 },
              { "color": "red",    "value": 85 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "tank_tick_duration_us_avg / 16667 * 100", "legendFormat": "avg % budget" },
        { "expr": "tank_tick_duration_us_p99 / 16667 * 100", "legendFormat": "p99 % budget" }
      ]
    },
    {
      "id": 20,
      "title": "JVM Heap Usage — Java Services",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\"}",
          "legendFormat": "{{service}} heap used"
        },
        {
          "expr": "jvm_memory_max_bytes{area=\"heap\"}",
          "legendFormat": "{{service}} heap max"
        }
      ]
    },
    {
      "id": 21,
      "title": "HTTP Request Rate — Java Services",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count[1m])",
          "legendFormat": "{{service}} {{uri}} {{status}}"
        }
      ]
    },
    {
      "id": 30,
      "title": "Active Matches over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 21, "w": 8, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "none", "min": 0 } },
      "targets": [{ "expr": "tank_active_matches", "legendFormat": "active matches" }]
    },
    {
      "id": 31,
      "title": "Game Server Memory (RSS)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 21, "w": 8, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "decmbytes" } },
      "targets": [{ "expr": "tank_process_memory_mb", "legendFormat": "server_tank.exe RSS" }]
    },
    {
      "id": 32,
      "title": "Kafka Events",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 21, "w": 8, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "none" } },
      "targets": [
        { "expr": "tank_kafka_events_consumed_total", "legendFormat": "match.create consumed" },
        { "expr": "tank_kafka_events_produced_total", "legendFormat": "match.result produced" }
      ]
    },
    {
      "id": 40,
      "title": "Architecture Comparison — Baseline vs IOCP (from benchmark)",
      "type": "table",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 7 },
      "options": { "footer": { "show": false } },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "avg_us" },
            "properties": [{ "id": "displayName", "value": "Tick Avg (µs)" }] },
          { "matcher": { "id": "byName", "options": "p99_us" },
            "properties": [{ "id": "displayName", "value": "Tick P99 (µs)" }] },
          { "matcher": { "id": "byName", "options": "max_us" },
            "properties": [{ "id": "displayName", "value": "Tick Max (µs)" }] },
          { "matcher": { "id": "byName", "options": "overrun_rate" },
            "properties": [{ "id": "displayName", "value": "Overrun Rate" }] }
        ]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {}
        }
      ],
      "targets": [
        {
          "expr": "tank_tick_duration_us_avg",
          "legendFormat": "IOCP (current)",
          "instant": true
        }
      ],
      "description": "Baseline A (single-thread): avg=990µs p99=14500µs max=109563µs overrun=0.1%\nIOCP (16 workers):         avg=228µs p99=700µs   max=32120µs overrun=0.08%\nCurrent live measurement shown above — compare với baseline trong performance_benchmark.md"
    }
  ]
}
