{
  "title": "Worst-Case Live Benchmark",
  "uid": "wc-live-bench",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "tags": ["benchmark", "worst-case", "live"],
  "templating": {
    "list": [
      {
        "name": "players",
        "label": "Players",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": ""},
        "query": "label_values(wc_players, players)",
        "refresh": 2,
        "sort": 3,
        "current": {},
        "includeAll": false,
        "multi": false,
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1, "type": "stat", "gridPos": {"x":0,"y":0,"w":4,"h":4},
      "title": "GPC (Games Per Core)",
      "description": "floor(16667µs / P99). Số match tối đa / tick / core",
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color":"red","value":0},
              {"color":"orange","value":2},
              {"color":"green","value":3}
            ]
          },
          "mappings": []
        }
      },
      "options": {"reduceOptions": {"calcs":["lastNotNull"]}, "orientation":"auto","textMode":"auto","colorMode":"background"},
      "targets": [{"expr": "wc_gpc{players=\"5\"}", "legendFormat": "GPC"}]
    },
    {
      "id": 2, "type": "stat", "gridPos": {"x":4,"y":0,"w":4,"h":4},
      "title": "Total P99 (µs)",
      "description": "99th percentile tick time — dùng để tính GPC",
      "fieldConfig": {
        "defaults": {
          "unit": "µs",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color":"green","value":0},
              {"color":"orange","value":8000},
              {"color":"red","value":16667}
            ]
          }
        }
      },
      "options": {"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"background"},
      "targets": [{"expr":"wc_total_p99_us{players=\"5\"}","legendFormat":"P99 µs"}]
    },
    {
      "id": 3, "type": "stat", "gridPos": {"x":8,"y":0,"w":4,"h":4},
      "title": "Budget Used @ P99",
      "description": "P99 / 16667µs × 100%",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color":"green","value":0},
              {"color":"orange","value":50},
              {"color":"red","value":75}
            ]
          }
        }
      },
      "options": {"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"background"},
      "targets": [{"expr":"wc_budget_pct{players=\"5\"}","legendFormat":"Budget %"}]
    },
    {
      "id": 4, "type": "stat", "gridPos": {"x":12,"y":0,"w":4,"h":4},
      "title": "Players",
      "description": "Số player đang được giả lập",
      "fieldConfig": {"defaults":{"unit":"none","color":{"mode":"fixed","fixedColor":"blue"}}},
      "options": {"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"value"},
      "targets": [{"expr":"wc_players{players=\"5\"}","legendFormat":"Players"}]
    },
    {
      "id": 5, "type": "stat", "gridPos": {"x":16,"y":0,"w":4,"h":4},
      "title": "Steady Bullets",
      "description": "Số đạn đang bay ở steady-state",
      "fieldConfig": {"defaults":{"unit":"none","color":{"mode":"fixed","fixedColor":"orange"}}},
      "options": {"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"value"},
      "targets": [{"expr":"wc_steady_bullets{players=\"5\"}","legendFormat":"Bullets"}]
    },
    {
      "id": 6, "type": "stat", "gridPos": {"x":20,"y":0,"w":4,"h":4},
      "title": "Overruns",
      "description": "Ticks vượt budget 16667µs trong window gần nhất",
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {"mode":"absolute","steps":[{"color":"green","value":0},{"color":"red","value":1}]}
        }
      },
      "options": {"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"background"},
      "targets": [{"expr":"wc_overruns{players=\"5\"}","legendFormat":"Overruns"}]
    },

    {
      "id": 10, "type": "timeseries", "gridPos": {"x":0,"y":4,"w":12,"h":8},
      "title": "Tick Time — Avg + P99 theo thời gian",
      "description": "Cập nhật mỗi ~10s (600 ticks). Xem xu hướng P99 có ổn định không.",
      "fieldConfig": {
        "defaults": {"unit":"µs","custom":{"lineWidth":2,"fillOpacity":10}},
        "overrides": [
          {"matcher":{"id":"byName","options":"Total P99"},"properties":[{"id":"color","value":{"fixedColor":"orange","mode":"fixed"}},{"id":"custom.lineWidth","value":3}]},
          {"matcher":{"id":"byName","options":"Total Avg"},"properties":[{"id":"color","value":{"fixedColor":"yellow","mode":"fixed"}}]},
          {"matcher":{"id":"byName","options":"Physics P99"},"properties":[{"id":"color","value":{"fixedColor":"red","mode":"fixed"}}]},
          {"matcher":{"id":"byName","options":"Bullet P99"},"properties":[{"id":"color","value":{"fixedColor":"blue","mode":"fixed"}}]},
          {"matcher":{"id":"byName","options":"Snap P99"},"properties":[{"id":"color","value":{"fixedColor":"green","mode":"fixed"}}]}
        ]
      },
      "options": {"tooltip":{"mode":"multi"}},
      "targets": [
        {"expr":"wc_total_p99_us{players=\"5\"}",   "legendFormat":"Total P99"},
        {"expr":"wc_total_avg_us{players=\"5\"}",   "legendFormat":"Total Avg"},
        {"expr":"wc_physics_p99_us{players=\"5\"}", "legendFormat":"Physics P99"},
        {"expr":"wc_bullet_p99_us{players=\"5\"}",  "legendFormat":"Bullet P99"},
        {"expr":"wc_snap_p99_us{players=\"5\"}",    "legendFormat":"Snap P99"}
      ]
    },

    {
      "id": 11, "type": "bargauge", "gridPos": {"x":12,"y":4,"w":12,"h":8},
      "title": "Phase Breakdown — P99 (µs)",
      "description": "So sánh thời gian P99 của từng pha xử lý",
      "fieldConfig": {
        "defaults": {
          "unit":"µs","min":0,
          "thresholds":{"mode":"absolute","steps":[{"color":"green","value":0},{"color":"orange","value":5000},{"color":"red","value":10000}]},
          "custom":{"orientation":"horizontal"}
        }
      },
      "options": {"displayMode":"gradient","reduceOptions":{"calcs":["lastNotNull"]},"orientation":"horizontal"},
      "targets": [
        {"expr":"wc_bullet_p99_us{players=\"5\"}",  "legendFormat":"Bullet P99"},
        {"expr":"wc_physics_p99_us{players=\"5\"}", "legendFormat":"Physics P99 ⚠"},
        {"expr":"wc_snap_p99_us{players=\"5\"}",    "legendFormat":"Snap P99"},
        {"expr":"wc_total_p99_us{players=\"5\"}",   "legendFormat":"Total P99"}
      ]
    },

    {
      "id": 12, "type": "timeseries", "gridPos": {"x":0,"y":12,"w":12,"h":8},
      "title": "GPC theo thời gian",
      "description": "GPC = floor(16667 / total_P99). Kỳ vọng: ổn định, không giảm",
      "fieldConfig": {
        "defaults": {
          "unit":"none","min":0,
          "custom":{"lineWidth":3,"fillOpacity":15},
          "color":{"mode":"fixed","fixedColor":"green"},
          "thresholds":{"mode":"absolute","steps":[{"color":"red","value":0},{"color":"orange","value":2},{"color":"green","value":3}]}
        }
      },
      "targets": [{"expr":"wc_gpc{players=\"5\"}","legendFormat":"GPC"}]
    },

    {
      "id": 13, "type": "timeseries", "gridPos": {"x":12,"y":12,"w":12,"h":8},
      "title": "Budget Used @ P99 (%)",
      "description": "% budget tick 60Hz bị sử dụng. Dưới 50% = an toàn",
      "fieldConfig": {
        "defaults": {
          "unit":"percent","min":0,"max":100,
          "custom":{"lineWidth":2,"fillOpacity":20},
          "thresholds":{"mode":"absolute","steps":[{"color":"green","value":0},{"color":"orange","value":50},{"color":"red","value":75}]}
        }
      },
      "targets": [
        {"expr":"wc_budget_pct{players=\"5\"}","legendFormat":"Budget %"}
      ]
    },

    {
      "id": 14, "type": "stat", "gridPos": {"x":0,"y":20,"w":6,"h":4},
      "title": "Overhead / Switch (Avg)",
      "description": "Thời gian mất khi core chuyển từ match này sang match khác (avg). overhead = wall_time - sum(individual). overhead/switch = overhead/(K-1)",
      "fieldConfig": {
        "defaults": {
          "unit": "µs",
          "thresholds": {"mode":"absolute","steps":[{"color":"green","value":0},{"color":"yellow","value":100},{"color":"orange","value":500},{"color":"red","value":1000}]}
        }
      },
      "options": {"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"background"},
      "targets": [{"expr":"wc_overhead_per_switch_avg_us{players=\"5\"}","legendFormat":"Overhead/switch avg"}]
    },
    {
      "id": 15, "type": "stat", "gridPos": {"x":6,"y":20,"w":6,"h":4},
      "title": "Overhead / Switch (P99)",
      "description": "Task-switch overhead P99 — 99% lần chuyển task nhanh hơn giá trị này",
      "fieldConfig": {
        "defaults": {
          "unit": "µs",
          "thresholds": {"mode":"absolute","steps":[{"color":"green","value":0},{"color":"yellow","value":200},{"color":"orange","value":1000},{"color":"red","value":2000}]}
        }
      },
      "options": {"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"background"},
      "targets": [{"expr":"wc_overhead_per_switch_p99_us{players=\"5\"}","legendFormat":"Overhead/switch P99"}]
    },
    {
      "id": 16, "type": "timeseries", "gridPos": {"x":12,"y":20,"w":12,"h":4},
      "title": "Task-Switch Overhead theo thời gian",
      "description": "overhead/switch = (wall_time_K_matches - K×single_match_time) / (K-1). Chạy với --matches=K để đo.",
      "fieldConfig": {
        "defaults": {"unit":"µs","custom":{"lineWidth":2}},
        "overrides": [
          {"matcher":{"id":"byName","options":"Avg"},"properties":[{"id":"color","value":{"fixedColor":"yellow","mode":"fixed"}}]},
          {"matcher":{"id":"byName","options":"P99"},"properties":[{"id":"color","value":{"fixedColor":"orange","mode":"fixed"}}]}
        ]
      },
      "targets": [
        {"expr":"wc_overhead_per_switch_avg_us{players=\"5\"}","legendFormat":"Avg"},
        {"expr":"wc_overhead_per_switch_p99_us{players=\"5\"}","legendFormat":"P99"}
      ]
    },
    {
      "id": 20, "type": "text", "gridPos": {"x":0,"y":24,"w":24,"h":3},
      "title": "",
      "options": {
        "mode": "markdown",
        "content": "## 🎮 Đổi số player\n\n→ **[Mở trang điều khiển](http://localhost:9103/)** để nhập số player và xem kết quả real-time.\n\nBenchmark tự động chạy lại sau khi đổi players. Metrics cập nhật sau ~10 giây (600 ticks)."
      }
    }
  ]
}
